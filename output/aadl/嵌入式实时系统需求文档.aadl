package System 
 public 
   -- ======================================= 
   -- 顶层系统容器 
   -- ======================================= 
   system System 
   end System; 

   system implementation System.impl 
     subcomponents 
       MainProcessor : processor MainProcessor.impl; 
       HighPrecisionTimer : device HighPrecisionTimer.impl; 
       InterruptController : device InterruptController.impl; 
       SerialPort : device SerialPort.impl; 
       CANController : device CANController.impl; 
       EthernetInterface : device EthernetInterface.impl; 
       SystemClock : device SystemClock.impl; 
       WatchdogTimer : device WatchdogTimer.impl; 
       RAM : memory RAM.impl; 
       TaskSchedulerProcess : process TaskSchedulerProcess.impl; 
     end System.impl; 

   -- ======================================= 
   -- 软件组件定义 
   -- ======================================= 
   process TaskSchedulerProcess 
   end TaskSchedulerProcess; 

   process implementation TaskSchedulerProcess.impl 
     subcomponents 
       PreemptiveScheduler : thread PreemptiveScheduler.impl; 
       TimerService : thread TimerService.impl; 
       MemoryManager : thread MemoryManager.impl; 
       FileSystemDriver : thread FileSystemDriver.impl; 
     end TaskSchedulerProcess.impl; 

   thread PreemptiveScheduler 
   end PreemptiveScheduler; 

   thread implementation PreemptiveScheduler.impl 
   end PreemptiveScheduler.impl; 

   thread TimerService 
   end TimerService; 

   thread implementation TimerService.impl 
   end TimerService.impl; 

   thread MemoryManager 
   end MemoryManager; 

   thread implementation MemoryManager.impl 
   end MemoryManager.impl; 

   thread FileSystemDriver 
   end FileSystemDriver; 

   thread implementation FileSystemDriver.impl 
   end FileSystemDriver.impl; 

   -- ======================================= 
   -- 硬件组件定义 
   -- ======================================= 
   processor MainProcessor 
   end MainProcessor; 

   processor implementation MainProcessor.impl 
     subcomponents 
       TaskSchedulerProcess_runtime : virtual processor TaskSchedulerProcess_runtime.impl; 
     end MainProcessor.impl; 

   virtual processor TaskSchedulerProcess_runtime 
   end TaskSchedulerProcess_runtime; 

   virtual processor implementation TaskSchedulerProcess_runtime.impl 
   end TaskSchedulerProcess_runtime.impl; 

   device HighPrecisionTimer 
   end HighPrecisionTimer; 

   device implementation HighPrecisionTimer.impl 
   end HighPrecisionTimer.impl; 

   device InterruptController 
   end InterruptController; 

   device implementation InterruptController.impl 
   end InterruptController.impl; 

   device SerialPort 
   end SerialPort; 

   device implementation Serial
   end SerialPort.impl; 

   device CANController 
   end CANController; 

   device implementation CANController.impl 
   end CANController.impl; 

   device EthernetInterface 
   end EthernetInterface; 

   device implementation EthernetInterface.impl 
   end EthernetInterface.impl; 

   device SystemClock 
   end SystemClock; 

   device implementation SystemClock.impl 
   end SystemClock.impl; 

   device WatchdogTimer 
   end WatchdogTimer; 

   device implementation WatchdogTimer.impl 
   end WatchdogTimer.impl; 

   memory RAM 
   end RAM; 

   memory implementation RAM.impl 
   end RAM.impl;
end System;
